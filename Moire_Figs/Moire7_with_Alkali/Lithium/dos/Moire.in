include Moire7-0.666-0.333.ionpos
ion-species SG15/$ID_ONCV_PBE.upf
include Moire7.lattice
ion ${alkali} 0.3333333333 0.6666666666 ${d2} 0
electronic-SCF nIterations 1000
elec-smearing Fermi 0.00001
elec-initial-magnetization 0.1 no
spintype z-spin
kpoint-folding 12 12 1
coulomb-Interaction Slab 001
van-der-waals D3
dump-name ${alkali}-${d}.$VAR
dump End ElecDensity State BandEigs
