ion-species SG15/$ID_ONCV_PBE.upf
ion ${alkali} 0 0 0 0
include hBN.lattice
latt-scale ${scale} ${scale} 1 
spintype z-spin
elec-initial-magnetization 0.5 no
elec-smearing Fermi 0.00001
elec-n-bands 20
Coulomb-Interaction Slab 001
include bandstruct.kpoints
fix-electron-density ${alkali}-${scale}.$VAR
electronic-minimize nIterations 10000
dump-name ${alkali}-${scale}-bands.$VAR
dump End BandEigs
