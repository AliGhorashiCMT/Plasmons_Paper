ion-species SG15/$ID_ONCV_PBE.upf
ion ${alkali} 0 0 0 0
include hBN.lattice
latt-scale ${scale} ${scale} 1 
spintype z-spin
elec-initial-magnetization 0.5 no
elec-n-bands 20
elec-smearing Fermi 0.00001
Coulomb-Interaction Slab 001
kpoint-folding 12 12 1
electronic-SCF nIterations 10000
dump-name ${alkali}-${scale}.$VAR
dump End State ElecDensity BandEigs DOS

