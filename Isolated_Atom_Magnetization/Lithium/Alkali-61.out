	energyDiffThreshold	1e-08 \
	residualThreshold	1e-07 \
	mixFraction	0.5 \
	qMetric	0.8 \
	history	10 \
	nEigSteps	2 \
	eigDiffThreshold	1e-08 \
	mixedVariable	Density \
	qKerker	0.8 \
	qKappa	-1 \
	verbose	no \
	mixFractionMag	1.5
exchange-regularization WignerSeitzTruncated
fluid None
