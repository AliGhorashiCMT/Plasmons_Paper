include BN3BC.ionpos
include BN3BC.lattice
ion-species SG15/$ID_ONCV_PBE.upf
ion-species GBRV/$ID_pbe.uspp
Coulomb-Interaction Slab 001
elec-cutoff 25
elec-smearing Fermi 0.01
kpoint-folding 24 24 1
electronic-SCF nIterations 1000 energyDiffThreshold 1e-9
#electronic-minimize nIterations 10000 
#lattice-minimize nIterations 20 energyDiffThreshold 1e-8
dump End None
#dump End Lattice IonicPositions
#dump End State BandEigs ElecDensity

