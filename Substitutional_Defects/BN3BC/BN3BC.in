include BN3BC.ionpos
include BN3BC.lattice
ion-species SG15/$ID_ONCV_PBE.upf
elec-initial-magnetization 1 no
Coulomb-Interaction Slab 001
elec-smearing Fermi 0.00001
spintype z-spin
kpoint-folding 24 24 1
electronic-SCF nIterations 1000
#lattice-minimize nIterations 20
#dump End Lattice IonicPositions
#dump End State BandEigs ElecDensity
dump End None
